# --- Phase 1 ---
RESCALER_DB_PATH=/data/db.sqlite
# Hex-encoded 32-byte AES-GCM key used to encrypt Hetzner tokens at rest
# in the SQLite store. REQUIRED — the API container refuses to start
# without it. Auto-generation was removed because a freshly-built image
# would silently mint a new key, then fail to decrypt previously-stored
# tokens with a GCM authentication-tag mismatch. Generate with:
#   openssl rand -hex 32
# and paste the 64-char hex output here. Persist it somewhere durable
# (1Password, bitwarden, a secrets manager) — losing it locks you out of
# every Hetzner token in the database.
RESCALER_TOKEN_ENCRYPTION_KEY=

# --- Phase 2: serve mode ---
# REQUIRED when running `hetzner-rescaler serve`. The SvelteKit SPA reads
# this at build time (PUBLIC_INTERNAL_TOKEN) and sends it on every /api/*
# call as the X-Internal-Token header. Generate with:
#   head -c 32 /dev/urandom | xxd -p -c 64
RESCALER_INTERNAL_TOKEN=

# Listen address for the HTTP API. The Go binary binds 0.0.0.0 inside
# the container so Caddy can reach it; for local dev you may want
# 127.0.0.1:8080.
RESCALER_HTTP_ADDR=0.0.0.0:8080

# --- Phase 2: Better Auth ---
# REQUIRED. Shared secret for signing Better Auth session tokens. Must
# be at least 32 characters. Generate with:
#   head -c 32 /dev/urandom | base64
BETTER_AUTH_SECRET=

# Gate new-account creation on the web UI + Better Auth's
# /api/auth/sign-up/email endpoint. When `true`, signups are rejected
# at the server (HTTP 403) and the login page hides the "switch to
# sign up" toggle, so the only way to onboard a new account is via an
# already-authenticated admin. Default is unset (= signups allowed).
# Typical workflow: leave unset while creating the very first admin
# account, then set DISABLE_SIGNUP=true and restart rescaler-web to
# lock the door.
#   true   → signups disabled (recommended after first user exists)
#   unset  → signups enabled (default)
DISABLE_SIGNUP=false

# Public origin the browser uses to reach the stack. Caddy will listen
# here; Better Auth uses it for cookie scoping and redirect URLs.
# Operators putting TLS in front should use https:// instead.
BETTER_AUTH_URL=http://localhost:8080

# Path to the SQLite file Better Auth shares with rescaler-api. Inside
# the bundled docker-compose this is the shared volume mount; for local
# dev (bun run dev), use any writable path.
DATABASE_URL=/data/db.sqlite
