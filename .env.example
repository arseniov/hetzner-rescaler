# ----------------------------------------------------------------------------
# hetzner-rescaler — environment variables template
# Copy to `.env` and fill in. All values shown are placeholders.
# ----------------------------------------------------------------------------

# Path to the SQLite database file. Leave unset to accept the binary default
# (~/.hetzner-rescaler/db.sqlite locally, /data/db.sqlite in Docker).
# RESCALER_DB_PATH=/data/db.sqlite

# 32-byte (256-bit) hex-encoded key used to encrypt Hetzner tokens at rest.
# If unset, the binary generates one on first run and writes it to
# ~/.hetzner-rescaler/key (or /data/key in Docker). Backing up the DB
# without this key makes the encrypted tokens unrecoverable.
# Generate with: openssl rand -hex 32
# RESCALER_TOKEN_ENCRYPTION_KEY=

# Loopback HTTP address the `serve` command binds to. Only relevant in phase 2.
# RESCALER_HTTP_ADDR=127.0.0.1:8080

# --- Phase 2 (web UI) — leave commented out in phase 1 ---
# Shared secret between the SvelteKit SPA and the Go engine. Required in
# `serve` mode. Generate with: openssl rand -hex 32
# RESCALER_INTERNAL_TOKEN=

# Authorizer (sibling auth container) connection.
# AUTHORIZER_URL=http://authorizer:8080
# AUTHORIZER_CLIENT_ID=
