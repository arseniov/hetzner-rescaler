# --- Phase 1 ---
RESCALER_DB_PATH=/data/db.sqlite
# Hex-encoded 32-byte AES-GCM key. Leave blank to auto-generate on first run
# (the key is then written to /data/key with mode 0600).
RESCALER_TOKEN_ENCRYPTION_KEY=

# --- Phase 2: serve mode ---
# REQUIRED when running `hetzner-rescaler serve`. The SvelteKit SPA reads
# this at build time (PUBLIC_INTERNAL_TOKEN) and sends it on every /api/*
# call as the X-Internal-Token header. Generate with:
#   head -c 32 /dev/urandom | xxd -p -c 64
RESCALER_INTERNAL_TOKEN=

# Loopback listen address for the HTTP API + SPA. Default 127.0.0.1:8080.
RESCALER_HTTP_ADDR=127.0.0.1:8080

# --- Phase 2: Authorizer (sibling container) ---
# Public URL of the Authorizer container as the browser sees it.
# In the bundled docker-compose stack this is http://localhost:8080.
AUTHORIZER_URL=http://localhost:8080

# Authorizer OAuth client id. Must match --client-id on the authorizer
# container.
AUTHORIZER_CLIENT_ID=rescaler-web

# The Authorizer container's own env (paste into docker-compose override
# or into its own .env):
# AUTHORIZER_JWT_SECRET=...
# AUTHORIZER_ADMIN_SECRET=...
# AUTHORIZER_CLIENT_SECRET=...
