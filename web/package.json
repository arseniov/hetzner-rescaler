{
  "name": "hetzner-rescaler-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.1.38",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "DATABASE_URL=\"${DATABASE_URL:-/tmp/build.db}\" BETTER_AUTH_SECRET=\"${BETTER_AUTH_SECRET:-build-only-placeholder-secret-must-be-at-least-32-chars}\" sh -c 'svelte-kit sync && vite build'",
    "preview": "bun build/index.js",
    "start": "bun build/index.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/lib/server/migrate.ts",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "apexcharts": "^4.7.0",
    "better-auth": "^1.0.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.0",
    "lucide-svelte": "^1.0.1",
    "mode-watcher": "^1.1.0",
    "svelte-dnd-action": "^0.9.55",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.20.2",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/svelte": "^5.4.2",
    "autoprefixer": "^10.4.20",
    "bun-types": "^1.1.38",
    "drizzle-kit": "^0.28.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
